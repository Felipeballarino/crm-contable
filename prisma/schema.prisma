generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum Role {
  ADMIN
  STAFF
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum ExpirationStatus {
  PENDING
  DONE
  OVERDUE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum InteractionType {
  CALL
  MEETING
  EMAIL
  NOTE
}

enum PaymentStatus {
  PENDING
  PAID
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Studio {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  plan             Plan     @default(FREE)
  alertEmail       String?
  alertDaysBefore  Int      @default(5)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users                 User[]
  clients               Client[]
  expirations           Expiration[]
  tasks                 Task[]
  interactions          Interaction[]
  recurringExpirations  RecurringExpiration[]
  payments              Payment[]
  documents             Document[]
}

model User {
  id        String   @id @default(cuid())
  studioId  String
  name      String
  email     String
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studio       Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  clients      Client[]      @relation("ClientResponsible")
  tasks        Task[]        @relation("TaskAssignee")
  interactions Interaction[]
  documents    Document[]

  @@unique([studioId, email])
  @@index([studioId])
}

model Client {
  id                 String       @id @default(cuid())
  studioId           String
  razonSocial        String
  cuit               String
  tipoSocietario     String?
  condicionIva       String?
  actividadPrincipal String?
  inicioActividad    DateTime?
  inscriptoIIBB      Boolean      @default(false)
  contactoNombre     String?
  contactoEmail      String?
  contactoTel        String?
  whatsapp           String?
  domicilio          String?
  responsableId      String?
  honorarios         Decimal?     @db.Decimal(12, 2)
  notas              String?      @db.Text
  status             ClientStatus @default(ACTIVE)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  studio       Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  responsable  User?         @relation("ClientResponsible", fields: [responsableId], references: [id], onDelete: SetNull)
  expirations          Expiration[]
  tasks                Task[]
  interactions         Interaction[]
  recurringExpirations RecurringExpiration[]
  payments             Payment[]
  documents            Document[]

  @@unique([studioId, cuit])
  @@index([studioId])
  @@index([studioId, status])
}

model Expiration {
  id               String           @id @default(cuid())
  clientId         String
  studioId         String
  tipo             String
  descripcion      String?
  fechaVencimiento DateTime
  status           ExpirationStatus @default(PENDING)
  alertSent        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([studioId, status])
  @@index([studioId, fechaVencimiento])
  @@index([clientId])
}

model Task {
  id           String       @id @default(cuid())
  clientId     String
  studioId     String
  assignedToId String?
  titulo       String
  descripcion  String?      @db.Text
  prioridad    TaskPriority @default(MEDIUM)
  status       TaskStatus   @default(TODO)
  dueDate      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  studio     Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([studioId])
  @@index([studioId, status])
  @@index([clientId])
  @@index([assignedToId])
}

model Interaction {
  id          String          @id @default(cuid())
  clientId    String
  studioId    String
  userId      String
  tipo        InteractionType
  descripcion String          @db.Text
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([clientId])
}

model Payment {
  id        String        @id @default(cuid())
  clientId  String
  studioId  String
  month     Int
  year      Int
  amount    Decimal       @db.Decimal(12, 2)
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  notas     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@unique([studioId, clientId, month, year])
  @@index([studioId, month, year])
  @@index([clientId])
}

model Document {
  id           String   @id @default(cuid())
  clientId     String
  studioId     String
  uploadedById String
  name         String
  size         Int
  mimeType     String
  storagePath  String
  createdAt    DateTime @default(now())

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  studio     Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([clientId])
}

model RecurringExpiration {
  id          String   @id @default(cuid())
  clientId    String
  studioId    String
  tipo        String
  descripcion String?
  dayOfMonth  Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([clientId])
}
